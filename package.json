{
  "name": "leopple-games",
  "private": true,
  "version": "0.0.0",
  "author": "Leonardo Trindade",
  "license": "MIT",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "20.4.3",
    "@commitlint/config-conventional": "20.4.3",
    "husky": "9.1.7",
    "@changesets/cli": "2.30.0",
    "prettier": "3.7.4",
    "turbo": "2.8.12",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": "24"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}