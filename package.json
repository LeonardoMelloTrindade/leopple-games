{
  "name": "leopple-games",
  "private": true,
  "version": "0.0.0",
  "author": "Leonardo Trindade",
  "license": "MIT",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "prepare": "husky",
    "docker:dev": "turbo run docker:dev",
    "docker:dev:down": "docker compose -f docker-compose.dev.yaml down",
    "docker:dev:build": "docker compose -f docker-compose.dev.yaml build"
  },
  "devDependencies": {
    "@commitlint/cli": "20.4.3",
    "@commitlint/config-conventional": "20.4.3",
    "husky": "9.1.7",
    "@changesets/cli": "2.30.0",
    "prettier": "3.5.3",
    "turbo": "2.8.12",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": "24.13.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "npm@11.6.2",
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-musl": "4.59.0"
  }
}