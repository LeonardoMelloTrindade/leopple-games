    "@vue/tsconfig": "0.8.1",
    "@leopple-games/typescript": "*",
    "@leopple-games/eslint": "*",
    "jsdom": "28.1.0",
    "npm-run-all2": "8.0.4",
    "typescript": "5.9.3",
    "vite": "7.3.1",
    "vite-plugin-vue-devtools": "8.0.6",
